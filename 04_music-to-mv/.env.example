# music-to-mv 环境配置模板
# 复制此文件为 .env 并填入实际 Token
# 示例: cp .env.example .env

# ── MiniMax Token Plan ─────────────────────────────────────
# 用于：图片生成（image-01）、音乐生成（music-2.6）、场景描述 LLM（MiniMax-M2.7）
# 获取地址: https://www.minimaxi.com/user-center/basic-information/interface-key
export MINIMAX_TOKEN='your_minimax_token_here'

# ── DeepSeek API（遗留，可留空）────────────────────────────
# 历史用途：场景描述 AI 生成。当前已切换到 MiniMax-M2.7（复用 MINIMAX_TOKEN），
# preflight.sh 不再校验此项；保留变量仅为向后兼容。
export DEEPSEEK_TOKEN=''

# ── OpenAI API（备选，用于 DALL-E 3）──────────────────────
export OPENAI_TOKEN='your_openai_token_here'

# ── 阿里云 DashScope（用于图片生成）────────────────────────
# 模型: wan2.2-t2i-plus（已验证可用）
# 获取地址: https://dashscope.console.aliyun.com
export ALIBABA_TOKEN='your_alibaba_token_here'
export IMAGE_MODEL_ALIBABA='wan2.2-t2i-plus'

# ── 图片 API 选择 ──────────────────────────────────────────
# minimax    - MiniMax image-01（需要 MINIMAX_TOKEN）（默认）
# pollinations - Pollinations AI 免费无需 key
# dall-e     - OpenAI DALL-E 3（需要 OPENAI_TOKEN）
# alibaba    - 阿里云 wan2.2-t2i-plus（需要 ALIBABA_TOKEN）
export IMAGE_API_PROVIDER='minimax'
