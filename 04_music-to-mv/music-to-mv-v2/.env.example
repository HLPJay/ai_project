# Music-to-MV v2 环境变量配置

# ── MiniMax API ──
MINIMAX_TOKEN=your_minimax_token_here
MINIMAX_API_HOST=https://api.minimaxi.com

# ── LLM 模型配置 ──
LLM_MODEL=MiniMax-M2.7

# ── 图片生成 Provider ──
# 可选: minimax | alibaba | dall-e | pollinations
IMAGE_API_PROVIDER=minimax

# ── 阿里云（当 IMAGE_API_PROVIDER=alibaba） ──
ALIBABA_TOKEN=

# ── OpenAI（当 IMAGE_API_PROVIDER=dall-e） ──
OPENAI_TOKEN=

# ── Telegram 通知（可选） ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── 项目配置 ──
WORKSPACE_ROOT=~/.openclaw/workspace/mv
