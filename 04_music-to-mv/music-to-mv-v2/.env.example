# Music-to-MV v2 环境变量配置

# ── MiniMax API ──（向后兼容，非必需）
# 如果不使用拆分 Token，可只设置这两个
MINIMAX_TOKEN=your_minimax_token_here
MINIMAX_API_HOST=https://api.minimaxi.com

# ── MiniMax Token 拆分配置（推荐）──
# LLM 专用 Token（Plus 极速版，月度套餐）
MINIMAX_TOKEN_LLM=sk-cp-your_llm_token_here
MINIMAX_API_HOST_LLM=https://api.minimaxi.com

# 图片生成专用 Token（按量计费）
MINIMAX_TOKEN_IMAGE=sk-cp-your_image_token_here
MINIMAX_API_HOST_IMAGE=https://api.minimaxi.com

# ── LLM 模型配置 ──
LLM_MODEL=MiniMax-M2.7-highspeed

# ── 图片生成 Provider ──
# 可选: minimax | alibaba | dall-e | pollinations
IMAGE_API_PROVIDER=minimax
IMAGE_MODEL_POLLINATIONS=flux #pollinations免费模式下的生效

# ── 阿里云（当 IMAGE_API_PROVIDER=alibaba） ──
ALIBABA_TOKEN=

# ── OpenAI（当 IMAGE_API_PROVIDER=dall-e） ──
OPENAI_TOKEN=

# ── Telegram 通知（可选） ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── 项目配置 ──
WORKSPACE_ROOT=~/.openclaw/workspace/mv

# ── API 重试/超时（秒）──
# 通用默认：未设置分类型配置时使用
API_MAX_RETRIES=3
API_BASE_DELAY_SEC=2
API_MAX_DELAY_SEC=30
API_TIMEOUT_SEC=60

# 大模型/API 控制台日志
# API_LOG_ENABLED=true 时打印每次请求的开始、成功、失败摘要
# API_LOG_PROMPT/API_LOG_RESPONSE 默认关闭，避免完整 prompt/response 刷屏
API_LOG_ENABLED=false
API_LOG_RETRIES=true
API_LOG_PROMPT=false
API_LOG_RESPONSE=false
API_LOG_MAX_CHARS=500

# 歌词生成 API
LYRICS_API_MAX_RETRIES=2
LYRICS_API_BASE_DELAY_SEC=2
LYRICS_API_TIMEOUT_SEC=120

# 音乐生成 API（通常较慢，可适当调大）
MUSIC_API_MAX_RETRIES=2
MUSIC_API_BASE_DELAY_SEC=5
MUSIC_API_TIMEOUT_SEC=180

# 图片生成 API
IMAGE_API_MAX_RETRIES=3
IMAGE_API_BASE_DELAY_SEC=2
IMAGE_API_TIMEOUT_SEC=60

# 场景描述 LLM API（容易受模型思考和网络波动影响，单独给更长等待）
SCENE_DESC_API_MAX_RETRIES=3
SCENE_DESC_API_BASE_DELAY_SEC=2
SCENE_DESC_API_TIMEOUT_SEC=120
VARIANT_API_MAX_RETRIES=3
VARIANT_API_BASE_DELAY_SEC=2
VARIANT_API_TIMEOUT_SEC=120

# 图片下载
DOWNLOAD_MAX_RETRIES=3
DOWNLOAD_BASE_DELAY_SEC=2
DOWNLOAD_TIMEOUT_SEC=60

# Chat completion 输出长度。场景描述建议小批次，减少超时和 JSON 失败
SCENE_DESC_MAX_TOKENS=4096
SCENE_DESC_BATCH_SIZE=2
VARIANT_DESC_MAX_TOKENS=4096
VARIANT_DESC_BATCH_SIZE=4
VISUAL_BIBLE_MAX_TOKENS=2048
CREATIVE_BRIEF_MAX_TOKENS=2048

# ── 并发控制 ──
# MiniMax 图片接口容易因网络/限流超时，建议 1；本地或更稳 provider 可调 2-4
IMAGE_PARALLEL=1

# ── 歌词/音乐结构 ──
# adaptive 会根据主题、曲风、情绪和创意简报自动选择结构
# 可选: adaptive | classic_pop | cinematic | ancient_poem | ballad_story | ambient_mood | rock_build
LYRICS_STRUCTURE_MODE=adaptive
# 若填写自定义结构，会优先使用它，例如：
# LYRICS_STRUCTURE=[Intro] -> [Verse 1] -> [Refrain] -> [Instrumental Interlude] -> [Verse 2] -> [Refrain Variation] -> [Outro]
LYRICS_STRUCTURE=

# ── 本地处理超时（秒）──
ALIGN_TIMEOUT_SEC=600

# ── 歌词对齐：Whisper / Demucs ──
# true=使用 Whisper ASR 精准对齐；false=跳过 ASR，直接生成基础均匀 SRT，适合快速测试流程
ALIGN_ASR_ENABLED=true
# Whisper 中等模型，精度比 small/base 好，首次运行会下载模型，显存占用也更高
ALIGN_WHISPER_MODEL=medium
# medium 失败时依次降级；想更省显存可改成 small，并把 fallback 留 base,tiny
ALIGN_WHISPER_FALLBACK_MODELS=small,base,tiny
# auto=有 CUDA 显卡就用 cuda，否则 cpu；也可显式填 cuda / cuda:0 / cpu
ALIGN_WHISPER_DEVICE=auto
# 中文歌曲建议 zh；英文可用 en；留 zh 可以避免中文歌被错判语言
ALIGN_WHISPER_LANGUAGE=zh
# Demucs 人声分离，提升对齐准确度；失败会自动回退原始音频
ALIGN_DEMUCS_ENABLED=true
# auto=有 CUDA 显卡就用 cuda，否则 cpu；也可显式填 cuda / cuda:0 / cpu
ALIGN_DEMUCS_DEVICE=auto
# 检查 demucs 命令是否可用的等待秒数；卡在 Demucs 检查时可调小
ALIGN_DEMUCS_CHECK_TIMEOUT_SEC=10

SCRIPT_TIMEOUT_SEC=600
SCENE_ANALYSIS_TIMEOUT_SEC=180
FFMPEG_TIMEOUT_SEC=600
FFPROBE_TIMEOUT_SEC=10
KB_TIMEOUT_BUFFER_SEC=30

# ── Ken Burns 镜头运动 ──
# 抖动明显时优先降低 KB_ZOOM_END、KB_PAN_X、KB_PAN_Y
KB_ZOOM_START=1.0
KB_ZOOM_END=1.12
KB_PAN_X=30
KB_PAN_Y=18
KB_SUPERSAMPLE_SCALE=2

# 你想更稳，几乎不动：
# KB_ZOOM_END=1.06
# KB_PAN_X=10
# KB_PAN_Y=6

# 如果想完全静态，只保留淡入淡出：
# KB_ZOOM_END=1.0
# KB_PAN_X=0
# KB_PAN_Y=0

# ── 图片自动质检 ──
# 是否在 Step⑤-⑦ 批量生图后自动检查图片质量，并写入 metadata/image_quality_report.json
IMAGE_QUALITY_ENABLED=true
# 图片文件最小字节数。小于该值通常表示下载失败、接口返回错误页、空文件或损坏文件
IMAGE_QUALITY_MIN_FILE_SIZE=1000
# 图片最小宽度。小于该值判定为 resolution_too_small
IMAGE_QUALITY_MIN_WIDTH=512
# 图片最小高度。小于该值判定为 resolution_too_small
IMAGE_QUALITY_MIN_HEIGHT=512
# 灰度亮度标准差下限。越小说明越接近纯色/低信息量；小于该值判定为 low_visual_variance
IMAGE_QUALITY_MIN_STDDEV=6

# ── ComfyUI 本地生图（当 IMAGE_API_PROVIDER=comfyui）──
# 可选 provider: minimax | alibaba | dall-e | pollinations | comfyui
# 先启动 ComfyUI，确认浏览器能打开 http://127.0.0.1:8188
IMAGE_API_URL_COMFYUI=http://127.0.0.1:8188
# 填 ComfyUI/models/checkpoints 下的精确文件名；例如 Juggernaut XL 的 safetensors 文件名
IMAGE_MODEL_COMFYUI=
# 可选：自定义 ComfyUI API-format workflow JSON；留空时使用内置 SDXL 基础工作流
COMFYUI_WORKFLOW=
COMFYUI_WIDTH=1280
COMFYUI_HEIGHT=720
COMFYUI_STEPS=28
COMFYUI_CFG=4.5
COMFYUI_SAMPLER=dpmpp_2m
COMFYUI_SCHEDULER=karras
COMFYUI_TIMEOUT_SEC=300
COMFYUI_POLL_INTERVAL_SEC=1

# ── 歌词分段/分镜图片提示词生成模型 ──
# 默认 minimax；测试阿里云百炼 Qwen 时设为 alibaba_qwen。只影响 Step③.5 场景描述/变体/visual_bible。
SCENE_PROMPT_PROVIDER=minimax
# 阿里云百炼 API Key；也可复用 ALIBABA_TOKEN，但建议单独配置。
DASHSCOPE_API_KEY=
SCENE_PROMPT_MODEL=qwen-plus-2025-07-28
SCENE_PROMPT_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
SCENE_PROMPT_DISABLE_THINKING=true
